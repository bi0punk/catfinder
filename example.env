# Cámaras RTSP. Formato: nombre=url,nombre2=url2
RTSP_URLS=patio=rtsp://usuario:clave@192.168.1.50:554/stream1

# Split por cámara: none | vertical | horizontal
# vertical  -> corta el frame en izquierda/derecha
# horizontal -> corta el frame en superior/inferior
CAMERA_SPLITS=patio=vertical

# Ratio del corte por cámara. 0.5 = mitad exacta.
# Ejemplo: si la división real no está al centro, puedes moverla.
CAMERA_SPLIT_RATIOS=patio=0.5

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
MODEL_PATH=yolo11n.pt
TARGET_CLASSES=cat
CONFIDENCE_THRESHOLD=0.55
COOLDOWN_SECONDS=60
PROCESS_EVERY_N_FRAMES=5
PREVIEW_EVERY_N_FRAMES=2
SAVE_DIR=captures
RECONNECT_DELAY_SECONDS=5
JPEG_QUALITY=85
INFER_IMGSZ=960
REQUEST_TIMEOUT_SECONDS=20
DRAW_BOXES=true
WEB_HOST=0.0.0.0
WEB_PORT=8080
WEB_TITLE=CatFinder RTSP Monitor
MAX_EVENTS=50
STREAM_SLEEP_MS=60
