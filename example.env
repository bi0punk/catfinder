# ──────────────────────────────────────────────────────
# CatFinder – variables de entorno
# Copia este archivo como .env y edítalo.
# ──────────────────────────────────────────────────────
# ── Cámaras RTSP ──────────────────────────────────────
# Formato: nombre=url,nombre2=url2
RTSP_URLS=patio=rtsp://usuario:clave@192.168.1.50:554/stream1

# Split por cámara: none | vertical | horizontal
CAMERA_SPLITS=patio=none

# Ratio del corte (0.1–0.9). 0.5 = mitad exacta.
CAMERA_SPLIT_RATIOS=patio=0.5
# ── ROI por vista (opcional) ───────────────────────────
# Filtra detecciones fuera del área indicada.
# Formato: viewid=x1:y1:x2:y2
# Ejemplo: CAMERA_ROIS=patio__left=0:100:640:480
CAMERA_ROIS=

# ── Telegram (opcional) ────────────────────────────────
# Si TELEGRAM_ENABLED=false o los tokens están vacíos,
# las alertas Telegram se deshabilitan silenciosamente.
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Modelo YOLO ────────────────────────────────────────
MODEL_PATH=yolo11n.pt
TARGET_CLASSES=cat
CONFIDENCE_THRESHOLD=0.55
INFER_IMGSZ=960

# ── Detección y alertas ────────────────────────────────
COOLDOWN_SECONDS=60
PROCESS_EVERY_N_FRAMES=5
PREVIEW_EVERY_N_FRAMES=2
DRAW_BOXES=true

# ── Almacenamiento ─────────────────────────────────────
SAVE_DIR=captures
JPEG_QUALITY=85

# ── Conexión ───────────────────────────────────────────
RECONNECT_DELAY_SECONDS=5
REQUEST_TIMEOUT_SECONDS=20

# ── Web ────────────────────────────────────────────────
WEB_HOST=0.0.0.0
WEB_PORT=8080
WEB_TITLE=CatFinder RTSP Monitor
MAX_EVENTS=50
STREAM_SLEEP_MS=60
# Opcional: password para Basic Auth (vacío = sin autenticación)
WEB_PASSWORD=

# ── Log ────────────────────────────────────────────────
# Niveles: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
