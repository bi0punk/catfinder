[Unit]
Description=CatFinder MVP RTSP cat detector
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/catfinder_mvp
EnvironmentFile=/opt/catfinder_mvp/.env
ExecStart=/opt/catfinder_mvp/.venv/bin/python -m app.main
Restart=always
RestartSec=5
User=catfinder
Group=catfinder

[Install]
WantedBy=multi-user.target
