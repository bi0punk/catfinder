# CatFinder RTSP Monitor - configuración optimizada CPU/RAM
# Copia este archivo como .env y ajusta tus datos.

# Cámaras RTSP
# Formato: nombre=url,nombre2=url2
# Usa substream cuando exista. En Hikvision suele ser Streaming/Channels/102.
RTSP_URLS=patio24=rtsp://

# Split por cámara: none | vertical | horizontal
CAMERA_SPLITS=patio24=horizontal
CAMERA_SPLIT_RATIOS=patio24=0.5

# ROI opcional por vista: viewid=x1:y1:x2:y2
# Ejemplo: patio__full=80:120:900:620
CAMERA_ROIS=

# Modelo YOLO
# Recomendado: montar ./models:/models y usar /models/yolo11n.pt
MODEL_PATH=models/yolo11n.pt
TARGET_CLASSES=cat
CONFIDENCE_THRESHOLD=0.45
INFER_IMGSZ=416

# Frecuencia de trabajo
# Mayor valor = menos CPU/RAM. Para CPU-only con varias cámaras: 15-30.
PROCESS_EVERY_N_FRAMES=15
PREVIEW_EVERY_N_FRAMES=5
COOLDOWN_SECONDS=60
DRAW_BOXES=true

# Control de memoria
INFERENCE_QUEUE_SIZE=4
INFERENCE_QUEUE_POLICY=drop_oldest
DISK_QUEUE_SIZE=100
TELEGRAM_QUEUE_SIZE=50
MAX_EVENTS=50
MAX_FRAME_WIDTH=960
JPEG_QUALITY=70
STREAM_SLEEP_MS=120

# OpenCV / Torch threads
OPENCV_THREADS=1
OMP_NUM_THREADS=2
MKL_NUM_THREADS=2
TORCH_NUM_THREADS=2
TORCH_INTEROP_THREADS=1

# RTSP
RTSP_BUFFER_SIZE=1
RTSP_OPEN_TIMEOUT_MS=5000
RTSP_READ_TIMEOUT_MS=5000
RECONNECT_DELAY_SECONDS=5
RECONNECT_DELAY_MAX_SECONDS=60
OPENCV_FFMPEG_CAPTURE_OPTIONS=rtsp_transport;tcp|stimeout;5000000|max_delay;500000

# Archivo runtime
CONFIG_FILE=config.json

# Evidencias
SAVE_DIR=captures
SAVE_RAW_IMAGES=true
SAVE_ALERT_IMAGES=true
RETENTION_DAYS=14

# Telegram opcional
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
REQUEST_TIMEOUT_SECONDS=20

# Web
WEB_HOST=0.0.0.0
WEB_PORT=8080
WEB_TITLE=CatFinder RTSP Monitor
WEB_PASSWORD=

# Logs
LOG_LEVEL=INFO
